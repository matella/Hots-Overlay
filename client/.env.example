# Path to your HotS replay folder (optional — can be set in Settings UI)
REPLAY_DIR=C:\Users\<you>\Documents\Heroes of the Storm\Accounts\<account>\<toon>\Replays\Multiplayer

# URL of the overlay server (required)
SERVER_URL=http://localhost:3001

# Auth token — must match AUTH_TOKEN on the server (leave empty if server has none)
AUTH_TOKEN=

# Port for the client web UI (default: 3002)
CLIENT_PORT=3002
