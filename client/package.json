{
  "name": "hots-overlay-client",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "node client.js",
    "electron": "electron .",
    "predist": "node scripts/configure.js",
    "dist": "electron-builder"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.hots.overlay-client",
    "productName": "HotS Replay Client",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    },
    "files": [
      "main.js",
      "client.js",
      "src/**/*",
      "public/**/*",
      "node_modules/**/*",
      "!node_modules/**/test/**",
      "!node_modules/**/*.md"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/defaults.json",
        "to": "defaults.json"
      }
    ]
  }
}
