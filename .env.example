# Path to your HotS replay folder (required)
REPLAY_DIR=C:\Users\<you>\Documents\Heroes of the Storm\Accounts\<account>\<toon>\Replays\Multiplayer

# Your ToonHandle — found in the replay folder path (required)
TOON_HANDLE=2-Hero-1-0000000

# Server port (default: 3000)
PORT=3001

# Default game mode shown in the overlay (default: Storm League)
# GAME_MODE=Storm League

# SQLite database path (default: ./data/overlay.db)
# DB_PATH=./data/overlay.db

# Auth token for the upload endpoint (optional — leave empty to disable auth)
# AUTH_TOKEN=your-secret-token

# Custom display labels for game modes
# MODE_LABEL_Custom=Scrims
