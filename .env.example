# Path to your HotS replay folder (required)
REPLAY_DIR=C:\Users\<you>\Documents\Heroes of the Storm\Accounts\<account>\<toon>\Replays\Multiplayer

# Your ToonHandle — found in the replay folder path (required)
TOON_HANDLE=2-Hero-1-0000000

# Server port (default: 8080)
PORT=8080

# Default game mode shown in the overlay (default: Storm League)
# GAME_MODE=Storm League

# MongoDB connection URI (default: mongodb://localhost:27017/hots-overlay)
# MONGODB_URI=mongodb+srv://matthieuhella_db_user:<db_password>@cluster0.nzxkrja.mongodb.net/?appName=Cluster0

# MongoDB connection URI (default: mongodb://localhost:27017/hots-overlay)
# MONGODB_URI=mongodb+srv://matthieuhella_db_user:<db_password>@cluster0.nzxkrja.mongodb.net/?appName=Cluster0

# Auth token for the upload endpoint (optional — leave empty to disable auth)
# AUTH_TOKEN=your-secret-token

# Timezone for Docker (default: America/New_York) — see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# TZ=America/New_York

# Custom display labels for game modes
# MODE_LABEL_Custom=Scrims

# ─── Twitch Extension (optional — only needed for PubSub live updates) ────────
# Obtain these from dev.twitch.tv/console/extensions after registering the extension.
# TWITCH_CLIENT_ID=<Client ID from the extension's Settings tab>
# TWITCH_EXTENSION_SECRET=<Base64-encoded Extension Secret from the Settings tab>
# TWITCH_BROADCASTER_ID=<your numeric Twitch user ID, e.g. 123456789>

# ─── External EBS webhook (optional — for a separately-deployed EBS) ──────────
# When set, server.js will POST a new_game event to this URL after each replay is parsed.
# EBS_URL=https://your-ebs-host.example.com/webhook/new-game

# ─── MongoDB (optional — defaults to local mongo container in Docker Compose) ─
# MONGODB_URI=mongodb+srv://matthieuhella_db_user:<db_password>@cluster0.nzxkrja.mongodb.net/?appName=Cluster0

# ─── Local HTTPS (for Twitch Extension dev — not needed in production) ────────
# Enables a local HTTPS server for Twitch Extension "Local Test" mode.
# Requires mkcert-generated certificates. See DEVELOPMENT.md for setup instructions.
# HTTPS_PORT=8443
# SSL_KEY_PATH=./certs/localhost-key.pem
# SSL_CERT_PATH=./certs/localhost.pem
